# ── Javelin Video Analysis — .dockerignore ────────────────────────────────────

# バージョン管理
.git
.gitignore
.github

# Python キャッシュ
__pycache__
*.pyc
*.pyo
*.pyd
*.pyc
.Python
*.so

# 仮想環境
.venv
venv
env
.env.local
.env.production

# 秘密情報（本番環境では外部注入する）
.env

# テスト・開発ツール
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
htmlcov
.tox
*.egg-info
dist
build

# データ・出力ファイル（ボリュームでマウント）
data/
outputs/
logs/
uploads/

# ジョブデータ（ボリュームでマウント）
jobs/
comparisons/

# エディタ設定
.vscode
.idea
*.swp
*.swo

# OS ファイル
.DS_Store
Thumbs.db

# Node.js（Blender連携等で使う場合）
node_modules

# Blender連携
blender_bridge/__pycache__

# ドキュメントビルド
docs/_build

# ノートブック出力
*.ipynb_checkpoints
