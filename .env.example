# ── AWS / S3 設定 ──────────────────────────────────────────────────────────────
# AWSクレデンシャルは ~/.aws/credentials またはIAMロールで設定してください。
# このファイルにシークレットキーを直接書かないでください。

AWS_REGION=ap-northeast-1
JVA_BUCKET=your-bucket-name
JVA_S3_PREFIX=javelin-analysis
JVA_PRESIGNED_URL_EXPIRES_SECONDS=604800

# JVA_S3_PREFIX  : S3キーのプレフィックス (例: javelin-analysis/jobs/...)
# JVA_PRESIGNED_URL_EXPIRES_SECONDS : presigned URL の有効期限（秒）
#                  604800 = 7日間（IAMユーザーキー使用時の最大値）
# JVA_BUCKET が "your-bucket-name" のままの場合はS3機能は無効になります。
