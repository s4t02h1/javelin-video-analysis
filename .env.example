# ── AWS / S3 設定 ──────────────────────────────────────────────────────────────
# AWSクレデンシャルは ~/.aws/credentials またはIAMロールで設定してください。
# このファイルにシークレットキーを直接書かないでください。

AWS_REGION=ap-northeast-1
JVA_BUCKET=your-bucket-name
JVA_S3_PREFIX=javelin-analysis
JVA_PRESIGNED_URL_EXPIRES_SECONDS=604800

# JVA_S3_PREFIX  : S3キーのプレフィックス (例: javelin-analysis/jobs/...)
# JVA_PRESIGNED_URL_EXPIRES_SECONDS : presigned URL の有効期限（秒）
#                  604800 = 7日間（IAMユーザーキー使用時の最大値）
# JVA_BUCKET が "your-bucket-name" のままの場合はS3機能は無効になります。

# ── Phase 6: intake API 設定 ───────────────────────────────────────────────────

# FastAPI 受付API の認証キー（必ず強力なランダム文字列を設定してください）
# 未設定の場合は開発モードとして動作しますが、本番環境では必ず設定してください。
JVA_API_KEY=

# intake API の有効化フラグ（false にすると /v1/intakes が 503 を返す）
JVA_ENABLE_INTAKE_API=true

# ── Phase 6: LINE 連携設定（将来対応、現在は任意）───────────────────────────

# LINE Developers でチャネルを作成した場合に設定してください。
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_WEBHOOK_ENABLED=false

