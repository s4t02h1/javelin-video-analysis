# ── Javelin Video Analysis — .env.example ────────────────────────────────────
#
# 使用方法:
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)
#   .env を編集して本番値を設定してください。
#
# ⚠️  .env は絶対に Git にコミットしないでください。
#      .gitignore に .env が含まれていることを確認してください。
# ──────────────────────────────────────────────────────────────────────────────


# ── 基本設定 ──────────────────────────────────────────────────────────────────

# 実行環境 (local | staging | production)
JVA_ENV=local

# アプリ名
JVA_APP_NAME=javelin-video-analysis

# デバッグモード (true | false)
JVA_DEBUG=false

# データディレクトリ（ジョブ・キュー・受付データを格納）
# Docker: /app/data  ローカル: data
JVA_DATA_DIR=data

# 出力ディレクトリ
JVA_OUTPUT_DIR=outputs

# ログディレクトリ
JVA_LOG_DIR=logs

# アップロードディレクトリ
JVA_UPLOAD_DIR=uploads


# ── API 設定 ──────────────────────────────────────────────────────────────────

# FastAPI 認証キー（必ず強力なランダム文字列を設定してください）
# 生成例: python -c "import secrets; print(secrets.token_urlsafe(32))"
JVA_API_KEY=

# intake API の有効化 (true | false)
JVA_ENABLE_INTAKE_API=true

# Jobs API の有効化 (true | false)
JVA_ENABLE_JOBS_API=true


# ── ワーカー / キュー設定 ─────────────────────────────────────────────────────

# ワーカーのポーリング間隔（秒）
JVA_WORKER_POLL_INTERVAL_SECONDS=5

# ジョブ失敗時の最大リトライ回数
JVA_WORKER_MAX_RETRIES=1

# キューバックエンド（現在は file のみ。将来: redis）
JVA_QUEUE_BACKEND=file

# キュー保存ディレクトリ（JVA_DATA_DIR/queue がデフォルト）
JVA_QUEUE_DIR=data/queue

# バックグラウンドワーカーの有効化 (true | false)
JVA_ENABLE_BACKGROUND_WORKER=true

# 将来の Redis 移行用（Phase 8 では未使用）:
# JVA_QUEUE_BACKEND=redis
# REDIS_URL=redis://redis:6379/0


# ── AWS / S3 設定 ─────────────────────────────────────────────────────────────
# AWSクレデンシャルは ~/.aws/credentials またはIAMロールで設定してください。
# このファイルにシークレットキーを直接書かないでください。

AWS_REGION=ap-northeast-1

# S3バケット名（"your-bucket-name" のままにするとS3機能は無効）
JVA_BUCKET=your-bucket-name

# S3キーのプレフィックス
JVA_S3_PREFIX=javelin-analysis

# presigned URL の有効期限（秒）。604800 = 7日間
JVA_PRESIGNED_URL_EXPIRES_SECONDS=604800


# ── LINE 連携設定 ─────────────────────────────────────────────────────────────
# LINE Developers でチャネルを作成した場合に設定してください。

LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_WEBHOOK_ENABLED=false


# ── 管理画面設定 ──────────────────────────────────────────────────────────────

# 管理画面ポート
JVA_ADMIN_PORT=8501

# 管理画面パスワード（設定するとログイン画面が表示される。空の場合は制限なし）
JVA_ADMIN_PASSWORD=


# ── Phase 14: Webフロントエンド設定 ──────────────────────────────────────────

# フロントエンドのベース URL（末尾スラッシュなし）
# 設定すると管理画面の「P14. Web版ダッシュボード」に Web版 URL が表示されます
# 例: https://your-dashboard.example.com
JVA_FRONTEND_BASE_URL=

# フロントエンドから見た FastAPI の URL（docker-compose での内部通信に使用）
JVA_FRONTEND_API_URL=http://localhost:8000

# パブリックダッシュボード API の有効化 (true | false)
JVA_PUBLIC_DASHBOARD_ENABLED=true

# ダッシュボードトークンの有効期限（日数）
JVA_DASHBOARD_TOKEN_EXPIRES_DAYS=14

# CORS 許可オリジン（カンマ区切り）
# フロントエンドのオリジンを設定してください
JVA_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
